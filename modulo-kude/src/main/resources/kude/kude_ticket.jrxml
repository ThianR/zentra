<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="KuDE_Ticket" pageWidth="226" pageHeight="1000" columnWidth="206" leftMargin="10" rightMargin="10" topMargin="10" bottomMargin="10" isIgnorePagination="true">
	<parameter name="P_EMISOR_NOMBRE" class="java.lang.String"/>
	<parameter name="P_EMISOR_RUC" class="java.lang.String"/>
	<parameter name="P_EMISOR_DIRECCION" class="java.lang.String"/>
	<parameter name="P_EMISOR_TELEFONO" class="java.lang.String"/>
	<parameter name="P_TIMBRADO" class="java.lang.String"/>
	<parameter name="P_NUMERO_DOCUMENTO" class="java.lang.String"/>
	<parameter name="P_TIPO_DOCUMENTO_TEXTO" class="java.lang.String"/>
	<parameter name="P_FECHA_EMISION" class="java.lang.String"/>
	<parameter name="P_RECEPTOR_NOMBRE" class="java.lang.String"/>
	<parameter name="P_RECEPTOR_RUC" class="java.lang.String"/>
	<parameter name="P_TOTAL_OPERACION" class="java.lang.Double"/>
	<parameter name="P_TOTAL_GRAVADA_10" class="java.lang.Double"/>
	<parameter name="P_TOTAL_GRAVADA_5" class="java.lang.Double"/>
	<parameter name="P_TOTAL_EXENTA" class="java.lang.Double"/>
	<parameter name="P_TOTAL_IVA_10" class="java.lang.Double"/>
	<parameter name="P_TOTAL_IVA_5" class="java.lang.Double"/>
	<parameter name="P_CDC" class="java.lang.String"/>
	<parameter name="P_QR" class="java.lang.Object"/>
	<parameter name="P_LOGO" class="java.lang.Object"/>
	<parameter name="P_CANCELADO" class="java.lang.Boolean"/>
	
	<!-- Nuevos parámetros de Nota de Remisión y Transporte -->
	<parameter name="P_ES_REMISION" class="java.lang.Boolean"/>
	<parameter name="P_TRANSP_RUC" class="java.lang.String"/>
	<parameter name="P_TRANSP_NOMBRE" class="java.lang.String"/>
	<parameter name="P_CHOFER_DOC" class="java.lang.String"/>
	<parameter name="P_CHOFER_NOMBRE" class="java.lang.String"/>
	<parameter name="P_VEHICULO_MARCA" class="java.lang.String"/>
	<parameter name="P_VEHICULO_MATRICULA" class="java.lang.String"/>
	<parameter name="P_VEHICULO_TIPO" class="java.lang.String"/>
	<parameter name="P_VEHICULO_CHASIS" class="java.lang.String"/>
	<parameter name="P_MOTIVO_TRASLADO" class="java.lang.String"/>
	<parameter name="P_FECHA_INICIO_TRASLADO" class="java.lang.String"/>
	<parameter name="P_FECHA_FIN_TRASLADO" class="java.lang.String"/>
	<parameter name="P_KMS_RECORRIDO" class="java.lang.String"/>
	<parameter name="P_SALIDA_DIR" class="java.lang.String"/>
	<parameter name="P_ENTREGA_DIR" class="java.lang.String"/>

	<field name="codigo" class="java.lang.String"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="precioUnitario" class="java.lang.Double"/>
	<field name="montoTotalItem" class="java.lang.Double"/>
	<field name="unidadMedida" class="java.lang.String"/>

	<group name="TransporteGroup">
		<groupHeader>
			<band height="180">
				<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				<line>
					<reportElement x="0" y="2" width="206" height="1"/>
					<graphicElement>
						<pen lineStyle="Dashed"/>
					</graphicElement>
				</line>
				<staticText>
					<reportElement x="0" y="5" width="206" height="12"/>
					<textElement textAlignment="Center">
						<font fontName="SansSerif" size="8" isBold="true"/>
					</textElement>
					<text><![CDATA[--- DATOS DEL TRASLADO ---]]></text>
				</staticText>
				<textField textAdjust="StretchHeight">
					<reportElement x="0" y="18" width="206" height="150"/>
					<textElement>
						<font fontName="SansSerif" size="7"/>
					</textElement>
					<textFieldExpression><![CDATA["Motivo: " + $P{P_MOTIVO_TRASLADO} + "\n" +
"Inicio: " + $P{P_FECHA_INICIO_TRASLADO} + " | Fin: " + $P{P_FECHA_FIN_TRASLADO} + "\n" +
"Km Recorrido: " + $P{P_KMS_RECORRIDO} + " Km\n" +
"Pto. Partida: " + $P{P_SALIDA_DIR} + "\n" +
"Pto. Entrega: " + $P{P_ENTREGA_DIR} + "\n\n" +
"--- TRANSPORTISTA Y CHOFER ---\n" +
"Transp.: " + $P{P_TRANSP_NOMBRE} + "\n(RUC: " + $P{P_TRANSP_RUC} + ")\n" +
"Chofer: " + $P{P_CHOFER_NOMBRE} + "\n(Doc: " + $P{P_CHOFER_DOC} + ")\n" +
"Vehículo: " + $P{P_VEHICULO_MARCA} + " (" + $P{P_VEHICULO_TIPO} + ")\n" +
"Chapa: " + $P{P_VEHICULO_MATRICULA} + " | Chasis: " + $P{P_VEHICULO_CHASIS}]]></textFieldExpression>
				</textField>
				<line>
					<reportElement x="0" y="175" width="206" height="1"/>
					<graphicElement>
						<pen lineStyle="Dashed"/>
					</graphicElement>
				</line>
			</band>
		</groupHeader>
	</group>

	<group name="InvoiceTotalsGroup">
		<groupFooter>
			<band height="105">
				<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				<line>
					<reportElement x="0" y="2" width="206" height="1"/>
					<graphicElement>
						<pen lineStyle="Dashed"/>
					</graphicElement>
				</line>
				<staticText>
					<reportElement x="0" y="5" width="100" height="12"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<text><![CDATA[TOTAL EXENTA:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="5" width="106" height="12"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_EXENTA}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="0" y="17" width="100" height="12"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<text><![CDATA[TOTAL GRAV. 5%:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="17" width="106" height="12"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_GRAVADA_5}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="0" y="29" width="100" height="12"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<text><![CDATA[TOTAL GRAV. 10%:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="29" width="106" height="12"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_GRAVADA_10}]]></textFieldExpression>
				</textField>
				<line>
					<reportElement x="100" y="45" width="106" height="1"/>
				</line>
				<staticText>
					<reportElement x="0" y="50" width="100" height="12"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<text><![CDATA[LIQ. IVA 5%:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="50" width="106" height="12"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_IVA_5}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="0" y="62" width="100" height="12"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<text><![CDATA[LIQ. IVA 10%:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="62" width="106" height="12"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_IVA_10}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="0" y="85" width="100" height="15"/>
					<textElement verticalAlignment="Middle">
						<font fontName="SansSerif" size="10" isBold="true"/>
					</textElement>
					<text><![CDATA[TOTAL GS:]]></text>
				</staticText>
				<textField pattern="#,##0">
					<reportElement x="100" y="85" width="106" height="15"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="SansSerif" size="11" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{P_TOTAL_OPERACION}]]></textFieldExpression>
				</textField>
			</band>
		</groupFooter>
	</group>

	<background>
		<band height="400" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="50" width="206" height="300" forecolor="#FFCCCC">
					<printWhenExpression><![CDATA[$P{P_CANCELADO} != null && $P{P_CANCELADO}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle" rotation="Left">
					<font fontName="SansSerif" size="30" isBold="true"/>
				</textElement>
				<text><![CDATA[DOCUMENTO CANCELADO]]></text>
			</staticText>
		</band>
	</background>

	<title>
		<band height="195" splitType="Stretch">
			<image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
				<reportElement x="78" y="0" width="50" height="40"/>
				<imageExpression><![CDATA[$P{P_LOGO}]]></imageExpression>
			</image>
			<textField>
				<reportElement x="0" y="45" width="206" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="10" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{P_EMISOR_NOMBRE}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="65" width="206" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{P_EMISOR_DIRECCION}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="80" width="206" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA["RUC: " + $P{P_EMISOR_RUC}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="95" width="206" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA["Tel: " + $P{P_EMISOR_TELEFONO}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="115" width="206" height="1"/>
				<graphicElement>
					<pen lineStyle="Dashed"/>
				</graphicElement>
			</line>
			<textField>
				<reportElement x="0" y="120" width="206" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="9" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{P_TIPO_DOCUMENTO_TEXTO}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="135" width="206" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="9" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{P_NUMERO_DOCUMENTO}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="150" width="206" height="12"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA["Fecha: " + $P{P_FECHA_EMISION}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="162" width="206" height="12"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA["Cliente: " + ($P{P_RECEPTOR_NOMBRE} != null ? $P{P_RECEPTOR_NOMBRE} : "-")]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="174" width="206" height="12"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA["RUC: " + ($P{P_RECEPTOR_RUC} != null ? $P{P_RECEPTOR_RUC} : "-")]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<columnHeader>
		<band height="15" splitType="Stretch">
			<!-- FACTURA / AUTOFACTURA COLUMN HEADER -->
			<staticText>
				<reportElement x="0" y="0" width="100" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[DESCRIPCIÓN]]></text>
			</staticText>
			<staticText>
				<reportElement x="100" y="0" width="30" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[CANT]]></text>
			</staticText>
			<staticText>
				<reportElement x="130" y="0" width="76" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[TOTAL]]></text>
			</staticText>

			<!-- NOTA DE REMISION COLUMN HEADER -->
			<staticText>
				<reportElement x="0" y="0" width="120" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[DESCRIPCIÓN ITEM]]></text>
			</staticText>
			<staticText>
				<reportElement x="120" y="0" width="35" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[CANT]]></text>
			</staticText>
			<staticText>
				<reportElement x="155" y="0" width="51" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[U.M.]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="25" splitType="Stretch">
			<!-- FACTURA / AUTOFACTURA DETAIL -->
			<textField textAdjust="StretchHeight">
				<reportElement x="0" y="0" width="206" height="12">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="100" y="12" width="30" height="12">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0">
				<reportElement x="130" y="12" width="76" height="12">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{montoTotalItem}]]></textFieldExpression>
			</textField>

			<!-- NOTA DE REMISION DETAIL -->
			<textField textAdjust="StretchHeight">
				<reportElement x="0" y="0" width="120" height="24">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="120" y="0" width="35" height="12">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="155" y="0" width="51" height="12">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{unidadMedida} != null ? $F{unidadMedida} : "UNI"]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<summary>
		<band height="145" splitType="Stretch">
			<line>
				<reportElement x="0" y="2" width="206" height="1"/>
				<graphicElement>
					<pen lineStyle="Dashed"/>
				</graphicElement>
			</line>
			<textField>
				<reportElement x="0" y="5" width="206" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="SansSerif" size="7" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["CDC: " + $P{P_CDC}]]></textFieldExpression>
			</textField>
			<image scaleImage="RetainShape" hAlign="Center">
				<reportElement x="53" y="32" width="100" height="80"/>
				<imageExpression><![CDATA[$P{P_QR}]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="0" y="115" width="206" height="25" forecolor="#666666"/>
				<textElement textAlignment="Center">
					<font fontName="SansSerif" size="5"/>
				</textElement>
				<text><![CDATA[REPRESENTACIÓN GRÁFICA DE DOCUMENTO ELECTRÓNICO (XML)
Consulte validez con CDC en: https://ekuatia.set.gov.py/consultas/]]></text>
			</staticText>
		</band>
	</summary>
</jasperReport>
