				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción]]></text>
			</staticText>
			<staticText>
				<reportElement x="280" y="0" width="40" height="20">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Cant.]]></text>
			</staticText>
			<staticText>
				<reportElement x="320" y="0" width="70" height="20">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[P. Unitario]]></text>
			</staticText>
			<staticText>
				<reportElement x="390" y="0" width="50" height="20">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Exenta]]></text>
			</staticText>
			<staticText>
				<reportElement x="440" y="0" width="55" height="20">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[IVA 5%]]></text>
			</staticText>
			<staticText>
				<reportElement x="495" y="0" width="55" height="20">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[IVA 10%]]></text>
			</staticText>

			<!-- NOTA DE REMISION COLUMN HEADER -->
			<rectangle>
				<reportElement mode="Opaque" x="0" y="0" width="555" height="20" backcolor="#EFEFEF">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#999999"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="5" y="0" width="60" height="20">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Cod. Item]]></text>
			</staticText>
			<staticText>
				<reportElement x="70" y="0" width="50" height="20">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Cantidad]]></text>
			</staticText>
			<staticText>
				<reportElement x="125" y="0" width="50" height="20">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[U. Medida]]></text>
			</staticText>
			<staticText>
				<reportElement x="180" y="0" width="370" height="20">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="SansSerif" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción Detallada de la Mercadería]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="15" splitType="Stretch">
			<!-- FACTURA / AUTOFACTURA DETAIL -->
			<textField>
				<reportElement x="5" y="0" width="50" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="55" y="0" width="225" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="280" y="0" width="40" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0">
				<reportElement x="320" y="0" width="70" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{precioUnitario}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0">
				<reportElement x="390" y="0" width="50" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{tasaIva} == 0.0) ? $F{montoTotalItem} : 0.0]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0">
				<reportElement x="440" y="0" width="55" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{tasaIva} == 5.0) ? $F{montoTotalItem} : 0.0]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0">
				<reportElement x="495" y="0" width="55" height="15">
					<printWhenExpression><![CDATA[!$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{tasaIva} == 10.0) ? $F{montoTotalItem} : 0.0]]></textFieldExpression>
			</textField>

			<!-- NOTA DE REMISION DETAIL -->
			<textField>
				<reportElement x="5" y="0" width="60" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{codigo} != null ? $F{codigo} : "-"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="70" y="0" width="50" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="125" y="0" width="50" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{unidadMedida} != null ? $F{unidadMedida} : "UNI"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement x="180" y="0" width="370" height="15">
					<printWhenExpression><![CDATA[$P{P_ES_REMISION}]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<summary>
		<band height="90" splitType="Stretch">
			<image scaleImage="RetainShape">
				<reportElement x="10" y="5" width="80" height="80"/>
				<imageExpression><![CDATA[$P{P_QR}]]></imageExpression>
			</image>
			<textField>
				<reportElement x="100" y="15" width="450" height="20"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="9" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["CDC: " + $P{P_CDC}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="100" y="35" width="450" height="35" forecolor="#666666"/>
				<textElement>
					<font fontName="Arial" size="7"/>
				</textElement>
				<text><![CDATA[ESTE DOCUMENTO ES UNA REPRESENTACIÓN GRÁFICA DE UN DOCUMENTO ELECTRÓNICO (XML)
Consulte la validez de este Documento Electrónico con el número de CDC en: https://ekuatia.set.gov.py/consultas/
Información de interés del emisor: Si su documento electrónico presenta algún error, podrá solicitar la modificación dentro de las 72 horas siguientes de la emisión.]]></text>
			</staticText>
		</band>
	</summary>
</jasperReport>
